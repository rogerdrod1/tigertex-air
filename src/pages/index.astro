---
import '../global.css';
import settings from '../content/settings.json';
import hero from '../content/hero.json';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>TigerTex Air — Heating &amp; Cooling · Katy, TX</title>
  <meta name="description" content="Honest HVAC service for Katy &amp; West Houston. Preventive maintenance, repairs, and installations. Licensed, insured, locally owned." />

  <link rel="canonical" href="https://www.tigertexair.com/" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://www.tigertexair.com/" />
  <meta property="og:title" content="TigerTex Air — Heating &amp; Cooling · Katy, TX" />
  <meta property="og:description" content="Honest HVAC service for Katy &amp; West Houston. Preventive maintenance, repairs, and installations. Licensed, insured, locally owned." />
  <meta property="og:site_name" content="TigerTex Air" />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="TigerTex Air — HVAC · Katy, TX" />
  <meta name="twitter:description" content="Preventive maintenance, repairs, and installations. Serving Katy &amp; West Houston. Licensed, insured, locally owned." />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />

  <!-- Schema.org: LocalBusiness + HVACContractor -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "HVACBusiness"],
    "name": "TigerTex Air LLC",
    "description": "Licensed HVAC contractor serving Katy and West Houston. Specializing in AC repair, AC installation, heating, furnace repair, and indoor air quality.",
    "url": "https://www.tigertexair.com",
    "telephone": "+17132401082",
    "email": "info@tigertexair.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Katy",
      "addressRegion": "TX",
      "postalCode": "77494",
      "addressCountry": "US"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": 29.7858, "longitude": -95.8245 },
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"], "opens": "00:00", "closes": "23:59" }
    ],
    "areaServed": [
      { "@type": "City", "name": "Katy" },
      { "@type": "City", "name": "Cinco Ranch" },
      { "@type": "City", "name": "Fulshear" },
      { "@type": "City", "name": "Richmond" },
      { "@type": "City", "name": "Sugar Land" },
      { "@type": "City", "name": "Brookshire" }
    ],
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "1200", "bestRating": "5" },
    "priceRange": "$$"
  }
  </script>

  <!-- Schema.org: FAQPage -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How quickly can TigerTex Air respond to an AC repair?", "acceptedAnswer": { "@type": "Answer", "text": "TigerTex Air offers same-day service for calls placed before noon across Katy and West Houston. For emergencies, we are available 24/7." } },
      { "@type": "Question", "name": "What areas does TigerTex Air serve?", "acceptedAnswer": { "@type": "Answer", "text": "We serve Katy, Cinco Ranch, Fulshear, Richmond, Sugar Land, Brookshire, Fort Bend County, and West Houston, TX." } },
      { "@type": "Question", "name": "Is TigerTex Air licensed and insured in Texas?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. TigerTex Air LLC holds a valid Texas HVAC contractor license (TACLB) and is fully insured." } },
      { "@type": "Question", "name": "How much does an AC tune-up cost?", "acceptedAnswer": { "@type": "Answer", "text": "A one-time AC tune-up starts at $89 and includes a 21-point system inspection, coil and drain line cleaning, refrigerant and airflow check, and a written health report." } }
    ]
  }
  </script>
</head>
<body>

<!-- ══════════ ANNOUNCEMENT BAR ══════════ -->
<div class="announce">
  <div class="container">
    <div class="announce-left">
      <span class="dot"></span>
      <span>Same-day service available · Serving Katy &amp; West Houston</span>
    </div>
    <div class="announce-right">
      <span class="area-text">License #{settings.license}</span>
      <a href={`tel:+1${settings.phone.replace(/\D/g,'')}`}><i data-lucide="phone"></i> {settings.phone}</a>
    </div>
  </div>
</div>

<!-- ══════════ HEADER ══════════ -->
<header class="header">
  <div class="container">
    <a href="#top" class="logo" aria-label="TigerTex Air home">
      <img src="/images/TigerTex Logo with text.png" alt="TigerTex Air" class="logo-full" />
      <img src="/images/Picture 5.svg" alt="" class="logo-icon" />
      <img src="/images/Logo Only Name.svg" alt="TigerTex Air" class="logo-name" />
    </a>
    <nav class="nav">
      <a href="#services">Services</a>
      <a href="#why">Why Us</a>
      <a href="#area">Service Area</a>
    </nav>
    <div class="header-cta">
      <a href={`tel:+1${settings.phone.replace(/\D/g,'')}`} class="header-phone"><i data-lucide="phone-call"></i> {settings.phone}</a>
      <button class="btn btn-heat" data-book="">Book Service</button>
      <button class="hamburger" aria-label="Menu" aria-expanded="false">
        <i data-lucide="menu" class="icon-menu"></i>
        <i data-lucide="x" class="icon-close"></i>
      </button>
    </div>
  </div>
</header>

<!-- ══════════ MOBILE NAV ══════════ -->
<div class="mobile-nav">
  <button class="mobile-nav-close" aria-label="Close menu"><i data-lucide="x"></i></button>
  <a href="#services">Services</a>
  <a href="#why">Why Us</a>
  <a href="#plans">Plans</a>
  <a href="#area">Service Area</a>
  <a href="#reviews">Reviews</a>
  <button class="btn btn-heat btn-lg btn-block" data-book="">Book Service</button>
  <a href={`tel:+1${settings.phone.replace(/\D/g,'')}`} class="btn btn-ghost btn-lg btn-block" style="margin-top:10px"><i data-lucide="phone"></i> {settings.phone}</a>
</div>

<main id="top">

  <!-- ══════════ HERO ══════════ -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">{hero.eyebrow}</span>
        <h1>{hero.headlineBefore} <span class="heat">{hero.headlineAccent}</span></h1>
        <p class="hero-lead">{hero.lead}</p>
        <div class="hero-actions">
          <button class="btn btn-heat btn-lg" data-book=""><i data-lucide="calendar-check"></i> Book a service</button>
          <a href={`tel:+1${settings.phone.replace(/\D/g,'')}`} class="btn btn-ghost btn-lg"><i data-lucide="phone"></i> {settings.phone}</a>
        </div>
        <div class="hero-trust">
          <div class="stat"><b>Same-day</b><span>repairs &amp; diagnostics</span></div>
        </div>
      </div>
      <div class="hero-media">
        <div class="hero-img-slot">
          <img src="/images/hf_20260621_160148_e00e03aa-59fb-47f5-89c3-eb171110a604.png" alt="TigerTex Air HVAC service" width="640" height="460" />
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════ TRUST STRIP ══════════ -->
  <div class="trust-strip">
    <div class="container">
      <div class="trust-item"><i data-lucide="badge-check"></i> Licensed &amp; Insured ({settings.license})</div>
      <div class="trust-item"><i data-lucide="map-pin"></i> Locally Owned in Katy</div>
<div class="trust-item"><i data-lucide="shield-check"></i> 100% Satisfaction Guarantee</div>
      <div class="trust-item"><i data-lucide="clock"></i> 24/7 Emergency Service</div>
    </div>
  </div>

  <!-- ══════════ SERVICE AREA ══════════ -->
  <section id="area" class="sec area">
    <div class="container area-grid">
      <div class="reveal">
        <span class="eyebrow">Service area</span>
        <h2 style="font-size:var(--fs-h2);margin-top:14px">Proudly serving Katy &amp; West Houston.</h2>
        <p style="color:var(--text-muted);margin-top:14px">Locally owned and operated, never far. If you're nearby and don't see your neighborhood, give us a call.</p>
        <div class="area-chips">
          <span class="chip"><i data-lucide="map-pin"></i> Katy</span>
          <span class="chip"><i data-lucide="map-pin"></i> Cinco Ranch</span>
          <span class="chip"><i data-lucide="map-pin"></i> Fulshear</span>
          <span class="chip"><i data-lucide="map-pin"></i> Richmond</span>
          <span class="chip"><i data-lucide="map-pin"></i> Sugar Land</span>
          <span class="chip"><i data-lucide="map-pin"></i> Brookshire</span>
          <span class="chip"><i data-lucide="map-pin"></i> Fort Bend</span>
          <span class="chip"><i data-lucide="map-pin"></i> West Houston</span>
        </div>
        <div style="margin-top:28px">
          <button class="btn btn-primary" data-book=""><i data-lucide="calendar-check"></i> Check availability</button>
        </div>
      </div>
      <div class="area-map reveal">
        <img src="/images/Service Area.png" alt="TigerTex Air service area map, Katy and West Houston" width="560" height="360" style="width:100%;height:360px;object-fit:cover;border-radius:var(--radius-xl)" />
      </div>
    </div>
  </section>

  <!-- ══════════ SERVICES ══════════ -->
  <section id="services" class="sec">
    <div class="container">
      <div class="sec-head reveal">
        <span class="eyebrow">What we do</span>
        <h2>Straightforward service, clear pricing.</h2>
        <p>No surprise fees, no upsells. Pick what your system needs and we'll get it done right.</p>
      </div>
      <div class="svc-grid">
        <div class="svc-card reveal">
          <div class="svc-icon"><i data-lucide="shield-check"></i></div>
          <h3>Preventive Maintenance</h3>
          <p>To ensure your system keeps running right. Includes inspection, cleaning, and recommendations.</p>
          <a href="#" class="svc-link" data-book="Preventive Maintenance">Book your service <i data-lucide="arrow-right"></i></a>
        </div>
        <div class="svc-card reveal">
          <div class="svc-icon"><i data-lucide="star"></i></div>
          <h3>Advanced Preventive Maintenance</h3>
          <p>Everything in a standard tune-up, plus deeper diagnostics, refrigerant checks, and electrical load testing.</p>
          <a href="#" class="svc-link" data-book="Advanced Preventive Maintenance">Book advanced service <i data-lucide="arrow-right"></i></a>
        </div>
        <div class="svc-card reveal">
          <div class="svc-icon"><i data-lucide="clipboard-list"></i></div>
          <h3>Custom Work</h3>
          <p>Repairs, installations, or anything else. We assess the job and give you a straight number before work begins.</p>
          <a href="#" class="svc-link" data-book="Custom Work">Request a service <i data-lucide="arrow-right"></i></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════ VALUE PROPS ══════════ -->
  <section id="why" class="sec values">
    <div class="container">
      <div class="sec-head center reveal">
        <span class="eyebrow on-dark">Why TigerTex</span>
        <h2>Engineered comfort, honest service.</h2>
        <p>We treat your home like a system. That means precise diagnostics, clear pricing, and work that holds up.</p>
      </div>
      <div class="val-grid">
        <div class="val-card reveal">
          <div class="val-icon"><i data-lucide="zap"></i></div>
          <h3>Same-day service</h3>
          <p>Book before noon and we'll be out today across Katy and West Houston.</p>
        </div>
        <div class="val-card reveal">
          <div class="val-icon"><i data-lucide="receipt-text"></i></div>
          <h3>Upfront pricing</h3>
          <p>Flat-rate quotes approved before we start. No surprises on the invoice.</p>
        </div>
        <div class="val-card reveal">
          <div class="val-icon"><i data-lucide="shield-check"></i></div>
          <h3>Satisfaction guarantee</h3>
          <p>If it's not right, we make it right. Or you don't pay for the repair.</p>
        </div>
        <div class="val-card reveal">
          <div class="val-icon"><i data-lucide="user-check"></i></div>
          <h3>Owner on every job</h3>
          <p>You get me, not a crew. Every visit is handled personally, start to finish.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════ PROCESS ══════════ -->
  <section class="sec">
    <div class="container">
      <div class="sec-head center reveal">
        <span class="eyebrow">How it works</span>
        <h2>Three steps to comfort.</h2>
      </div>
      <div class="steps">
        <div class="step reveal">
          <div class="step-bar"></div>
          <div class="step-num">STEP 01</div>
          <h3>Book in 60 seconds</h3>
          <p>Pick a service and a time online, or call us. You'll get a confirmed window, not a vague "sometime today."</p>
        </div>
        <div class="step reveal">
          <div class="step-bar"></div>
          <div class="step-num">STEP 02</div>
          <h3>We diagnose precisely</h3>
          <p>Your tech tests the full system with instruments, then walks you through findings and a flat-rate quote.</p>
        </div>
        <div class="step reveal">
          <div class="step-bar"></div>
          <div class="step-num">STEP 03</div>
          <h3>Fixed right, first time</h3>
          <p>Approve the quote and we get to work. Most repairs done same-visit, backed by our guarantee.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════ CTA BAND ══════════ -->
  <section class="cta-band">
    <div class="container">
      <span class="eyebrow on-dark" style="justify-content:center">Don't sweat it</span>
      <h2 style="margin-top:14px">Texas heat won't wait. Neither do we.</h2>
      <p>Book online in under a minute, or call for 24/7 emergency service across Katy and West Houston.</p>
      <div class="cta-actions">
        <button class="btn btn-heat btn-lg" data-book=""><i data-lucide="calendar-check"></i> Book a service</button>
        <a href={`tel:+1${settings.phone.replace(/\D/g,'')}`} class="btn btn-ghost btn-lg on-dark"><i data-lucide="phone"></i> {settings.phone}</a>
      </div>
    </div>
  </section>

</main>

<!-- ══════════ FOOTER ══════════ -->
<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="#top" class="logo on-dark">
          <img src="/images/TigerTex Logo with text.png" alt="TigerTex Air" class="logo-full" />
          <img src="/images/Picture 5.svg" alt="" class="logo-icon" />
          <img src="/images/Logo Only Name.svg" alt="TigerTex Air" class="logo-name" />
        </a>
        <p>Honest heating &amp; cooling for Katy &amp; West Houston. Locally owned, Texas licensed, available 24/7.</p>
      </div>
      <div class="footer-col">
        <h4>Services</h4>
        <ul>
          <li><a href="#services">AC Repair</a></li>
          <li><a href="#services">AC Installation</a></li>
          <li><a href="#services">Heating &amp; Furnace</a></li>
          <li><a href="#services">Indoor Air Quality</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          <li><a href="#why">Why TigerTex</a></li>
          <li><a href="#area">Service Area</a></li>
          <li><a href="#" data-book="">Book Online</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Contact</h4>
        <ul>
          <li class="row"><i data-lucide="phone"></i> {settings.phone}</li>
          <li class="row"><i data-lucide="mail"></i> {settings.email}</li>
          <li class="row"><i data-lucide="map-pin"></i> {settings.cityStateZip}</li>
          <li class="row"><i data-lucide="clock"></i> 24/7 Emergency Service</li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <small>© {new Date().getFullYear()} TigerTex Air LLC · License #{settings.license} · All rights reserved.</small>
    </div>
  </div>
</footer>

<!-- ══════════ BOOKING MODAL (Netlify Forms) ══════════ -->
<div class="modal-overlay">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="booking-title">
    <div id="booking-body">
      <div class="modal-head">
        <div>
          <span class="eyebrow">Book service</span>
          <h3 id="booking-title">Request your appointment</h3>
          <p>Tell us what's going on, and we'll confirm your window by text.</p>
        </div>
        <button class="modal-close" data-close aria-label="Close"><i data-lucide="x"></i></button>
      </div>
      <!-- data-netlify="true" registers this form with Netlify at build time -->
      <form
        id="booking-form"
        class="modal-body"
        name="booking"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
      >
        <input type="hidden" name="form-name" value="booking" />
        <p style="display:none"><label>Don't fill this out: <input name="bot-field" /></label></p>
        <div class="field-row">
          <div class="field"><label for="f-first">First name</label><input id="f-first" type="text" name="first" required placeholder="Jane" /></div>
          <div class="field"><label for="f-phone">Phone</label><input id="f-phone" type="tel" name="phone" required placeholder="(281) 555-0000" /></div>
        </div>
        <div class="field">
          <label for="f-service">Service needed</label>
          <select id="f-service" name="service">
            <option>Preventive Maintenance</option>
            <option>Advanced Preventive Maintenance</option>
            <option>Diagnostics</option>
            <option>AC Repair</option>
            <option>AC Installation</option>
            <option>Heating &amp; Furnace</option>
            <option>Indoor Air Quality</option>
            <option>Commercial HVAC</option>
            <option>Custom Work</option>
            <option>Not sure, please advise</option>
          </select>
        </div>
        <div class="field-row">
          <div class="field"><label for="f-zip">ZIP code</label><input id="f-zip" type="text" name="zip" required placeholder="77494" /></div>
          <div class="field"><label for="f-date">Preferred date</label><input id="f-date" type="date" name="date" /></div>
        </div>
        <button type="submit" class="btn btn-heat btn-lg btn-block" style="margin-top:6px">
          <i data-lucide="calendar-check"></i> Request appointment
        </button>
        <p style="font-size:var(--fs-xs);color:var(--text-muted);text-align:center;margin-top:8px">
          Or call <a href={`tel:+1${settings.phone.replace(/\D/g,'')}`} style="color:var(--brand-primary);font-weight:600">{settings.phone}</a> for 24/7 emergencies.
        </p>
      </form>
    </div>
    <div id="booking-success" class="modal-success" style="display:none">
      <div class="ok"><i data-lucide="check"></i></div>
      <h3>Request received!</h3>
      <p>Thanks, a TigerTex dispatcher will text you within 15 minutes to confirm your appointment window.</p>
      <button class="btn btn-ghost" data-close style="margin-top:22px">Close</button>
    </div>
  </div>
</div>

<!-- Hero image placeholder styles -->
<style>
  .hero-img-slot {
    width: 100%;
    height: 460px;
    border-radius: 22px;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    background: var(--blue-100);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-img-slot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (max-width: 980px) {
    .hero-img-slot { height: 320px; }
  }
</style>

<script src="https://unpkg.com/lucide@0.474.0/dist/umd/lucide.min.js" defer></script>
<script src="/site.js" defer></script>
</body>
</html>
